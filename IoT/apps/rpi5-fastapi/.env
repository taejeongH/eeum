## .env
# HTTP
HOST=0.0.0.0
PORT=8080

# API Server
API_BASE_URL=https://i14a105.p.ssafy.io
ALBUM_SYNC_PATH=/api/iot/device/sync/album
VOICE_SYNC_PATH=/api/iot/device/sync/voice

# MQTT Broker
SERVER_HOST=i14a105.p.ssafy.io
SERVER_PORT=8888

# Device identity
CLIENT_ID=EEUM-R105

# MQTT Auth
MQTT_USERNAME=eeum_device
MQTT_PASSWORD=OJhsnNN1+YuREJ53zcdehVavQu1jsxG+

# Audio Input
AUDIO_IN_DEVICE=hw:CARD=Audio,DEV=0
AUDIO_OUT_DEVICE=hdmi:CARD=vc4hdmi0,DEV=0

ALARM_TTS_DEBOUNCE_SEC=8
AUDIO_RATE_HZ=48000
AUDIO_CHANNELS=2

AUDIO_START_DELAY_MS=100
AUDIO_DRAIN_FUDGE_SEC=0.4

AUDIO_WARMUP_MS=900
AUDIO_REWARM_IDLE_SEC=30
AUDIO_KEEPALIVE_SEC=12
AUDIO_KEEPALIVE_MS=350

AUDIO_APLAY_BUFFER_TIME_US=900000
AUDIO_APLAY_PERIOD_TIME_US=180000

# 앞부분 잘림 방지(프리롤 ms)
AUDIO_PREROLL_MS=600

# stderr 로그 너무 시끄러우면 0
AUDIO_LOG_STDERR=1

# Audio 안정화 옵션(HDMI drop 완화)
# stop_current 등으로 재생 중단될 때 aplay terminate 대신 EOF로 자연 종료 유도
AUDIO_SOFT_STOP=1

# ffmpeg mp3 probe 안정화(voice mp3 변칙 대응)
# 너무 크면 시작이 느릴 수 있어 적당히: 128k~512k 권장
AUDIO_FFPROBE_PROBESIZE=256k
# analyzeduration: 0은 공격적이라 100k~500k 권장
AUDIO_FFMPEG_ANALYZE_DURATION=200k

# TTS 잔향/하울링 가드(시작 후 이 시간 동안 VAD 판단만 무시)
FALL_ECHO_GUARD_SEC=0.35

# ---- STT anti-hallucination / noise gate ----
# 노이즈에서 "이 영상은" 같은 헛자막 줄이기
STT_NO_SPEECH_THRESHOLD=0.60
STT_LOG_PROB_THRESHOLD=-1.60
STT_COMPRESSION_RATIO_THRESHOLD=2.40

# 짧은 명령어 정확도(도와줘 등)
STT_BEAM_SIZE=5
STT_BEST_OF=5

# VAD가 잡음에 속는 것 방지: 프레임 RMS가 이 값 미만이면 speech로 안 봄
STT_MIN_FRAME_RMS=100

# HuggingFace
HF_HOME=/home/a105/.cache/huggingface
HUGGINGFACE_HUB_CACHE=/home/a105/.cache/huggingface/hub
TRANSFORMERS_CACHE=/home/a105/.cache/huggingface/transformers
HF_HUB_DISABLE_TELEMETRY=1
EEUM_STT_OFFLINE=0
EEUM_STT_MODEL=base

# local state files
DEVICE_PATH=./device.json
TOKEN_PATH=./token.json
DB_PATH=./app.db
VOICE_PATH=./voice
ALBUM_PATH=./album
PROFILE_PATH=./profile
DEFAULT_TTS_PATH=./tts_voice
WEB_DIST_PATH=./dist

# semaphore
DL_CONCURRENCY=3

# debug
EEUM_DEBUG=1